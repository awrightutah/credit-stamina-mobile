*\ 2.lock
*\ 2.xcodeproj/
*\ 2.xcworkspace/
"ios/Podfile 2"
"ios/Podfile 2.lock"
"ios/Podfile 3.lock"
"package-lock 2.json"

# macOS sync-conflict duplicates (iCloud Drive / Dropbox / Time Machine)
